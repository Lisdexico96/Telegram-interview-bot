# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (can be multiple, separated by commas)
# To get your chat ID, message @userinfobot on Telegram
ADMIN_CHAT_ID=your_chat_id_here

# OpenAI API key (for applicant evaluation)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Sheet (for saving passed applicants)
# See GOOGLE_SHEET_SETUP.txt for how to get these
GOOGLE_SHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional: tab/sheet name (default "Sheet1")
# GOOGLE_SHEET_TAB_NAME=Applicants
