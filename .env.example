# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (can be multiple, separated by commas)
# To get your chat ID, message @userinfobot on Telegram
ADMIN_CHAT_ID=your_chat_id_here

# -----------------------------------------------------------------------------
# Airtable – chatters table (Python bot)
# Required to save interview results: Name, Lastname, Replies, Status,
# Payment method, BTC address / wise name, Wise email, currency.
# See AIRTABLE_SETUP.txt for creating the base and token.
# -----------------------------------------------------------------------------
AIRTABLE_API_KEY=your_personal_access_token_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_NAME=Chatters

# -----------------------------------------------------------------------------
# Node bot only (AI evaluation + Google Sheet)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here
# GOOGLE_SHEET_ID=...  GOOGLE_SERVICE_ACCOUNT_JSON=...
